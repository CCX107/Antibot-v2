# Local runtime configuration for Antibot dashboard
# Copy this file to antibot.env and fill in your own local values.
# Never commit antibot.env to GitHub.

ANTIBOT_BASE_DIR=./data
ANTIBOT_ENV_FILE=./antibot.env

ANTIBOT_DATA_FILE=sensor_machine_2026_test.parquet

IFOREST_MODEL_FILE=antibot_pipeline_v2_exclude_eu.pkl
IFOREST_FEATURES_FILE=features_all_iforest_v2_exclude_eu.parquet

XGB_MODEL_FILE=xgb_model_mixed_v2_exclude_eu_mixed_gray.pkl
XGB_FEATURES_FILE=features_all_xgb_mixed_v2_exclude_eu_mixed_gray.parquet

IMPALA_HOST=your_impala_host
IMPALA_PORT=21050
IMPALA_DATABASE=your_impala_database
IMPALA_USER=your_impala_user
IMPALA_PASSWORD=your_impala_password
IMPALA_AUTH_MECHANISM=NOSASL
